---
const { t } = Astro.props;
import Layout from '../layouts/Layout.astro';
import Hero from '../sections/Hero.astro';
import AboutMe from '../sections/AboutMe.astro';
import PersonalInfo from '../sections/PersonalInfo.astro';
import Projects from '../sections/Projects.astro';
import Footer from '../sections/Footer.astro';
import Experience from '../sections/Experience.astro';
import Intro from '../sections/Intro.astro';
import Contact from '../sections/Contact.astro';
---

<Layout title={t.pageTitle}>
	<Intro t={t}/>
	<Hero t={t} />
	<main class="flex flex-col min-h-screen px-96">
		<PersonalInfo t={t} />
		<AboutMe t={t} />
		<Experience t={t} />
		<Projects t={t} />
		<Contact t={t} />
	</main>
	<Footer t={t} />
</Layout>
<style>
	@font-face {
            font-family: 'RobotoSlab';
            src: url('/fonts/RobotoSlab-VariableFont_wght.ttf') format('truetype');
            font-weight: 100 900; /* Define el rango de pesos si es aplicable */
            font-style: normal;
        }
	html {
		font-family: 'RobotoSlab', sans-serif;
		scroll-behavior: smooth;
	}
</style>